---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  as?: "h2" | "h3";
}

const { eyebrow, title, description, as: Tag = "h2" } = Astro.props;
---

<header class="max-w-prose">
  {eyebrow && (
    <p class="text-xs uppercase tracking-[0.2em] opacity-60">{eyebrow}</p>
  )}
  <Tag class="mt-3 text-2xl sm:text-3xl font-serif font-normal tracking-tightish">
    {title}
  </Tag>
  {description && (
    <p class="mt-4 text-base sm:text-lg opacity-80 leading-relaxed">
      {description}
    </p>
  )}
</header>
