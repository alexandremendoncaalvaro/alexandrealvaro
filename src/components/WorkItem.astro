---
import type { WorkItem } from "../data/site";

export interface Props {
  item: WorkItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
---

<article class="py-10 first:pt-0 border-t border-paper-line/70 first:border-0 dark:border-white/10">
  <div class="grid gap-6 md:grid-cols-[10rem_1fr]">
    <p class="text-xs uppercase tracking-[0.18em] opacity-60 md:pt-2">
      {item.kind}
    </p>
    <div class="max-w-prose">
      <h3 class="text-xl sm:text-2xl font-serif font-normal tracking-tightish">
        {item.title}
      </h3>
      <p class="mt-3 leading-relaxed opacity-85">
        {item.summary}
      </p>

      {!compact && (
        <>
          <dl class="mt-5 space-y-2 text-sm">
            <div class="flex gap-3">
              <dt class="shrink-0 w-14 uppercase tracking-[0.14em] text-[11px] opacity-50 pt-1">
                Role
              </dt>
              <dd class="opacity-85">{item.role}</dd>
            </div>
            {item.impact && (
              <div class="flex gap-3">
                <dt class="shrink-0 w-14 uppercase tracking-[0.14em] text-[11px] opacity-50 pt-1">
                  Impact
                </dt>
                <dd class="opacity-85">{item.impact}</dd>
              </div>
            )}
            {item.stack && item.stack.length > 0 && (
              <div class="flex gap-3">
                <dt class="shrink-0 w-14 uppercase tracking-[0.14em] text-[11px] opacity-50 pt-1">
                  Stack
                </dt>
                <dd class="opacity-70 font-mono text-[13px]">
                  {item.stack.join(" · ")}
                </dd>
              </div>
            )}
          </dl>

          {item.links && item.links.length > 0 && (
            <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
              {item.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="no-underline inline-flex items-center gap-1.5 border-b border-ink/60 pb-0.5 hover:border-ink dark:border-paper/60 dark:hover:border-paper"
                    rel="noopener"
                  >
                    {l.label}
                    <span aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </>
      )}
    </div>
  </div>
</article>
