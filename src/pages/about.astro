---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { about, links } from "../data/site";
---

<BaseLayout
  title="About"
  description="Building software since 2007 — AI systems, computer vision, software architecture, and production environments where reliability matters."
>
  <section class="enter container-page pt-20 sm:pt-24 pb-10">
    <SectionHeading eyebrow="About" title={about.title} as="h1" />
  </section>

  <section class="reveal container-page pb-16">
    <div class="flex flex-col sm:flex-row gap-10 sm:gap-14 items-start">
      <img
        src="/profile.webp"
        alt="Alexandre Mendonça Alvaro"
        width="192"
        height="192"
        class="w-44 h-44 sm:w-48 sm:h-48 object-cover object-top shrink-0 rounded-sm"
        loading="eager"
      />
      <div class="max-w-prose space-y-6 text-[17px] leading-relaxed opacity-90">
        {about.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <hr class="rule container-page" />

  <section class="reveal container-page py-16">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] opacity-60">
          {about.strengths.title}
        </p>
        <ul class="mt-5 space-y-2 text-[15px]">
          {
            about.strengths.items.map((item) => (
              <li class="pl-5 relative before:content-['—'] before:absolute before:left-0 before:opacity-50">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.18em] opacity-60">
          {about.stack.title}
        </p>
        <p class="mt-5 font-mono text-[14px] opacity-80 leading-relaxed">
          {about.stack.items.join(" · ")}
        </p>
      </div>
    </div>
  </section>

  <hr class="rule container-page" />

  <section class="container-page py-16 sm:py-20">
    <div class="max-w-prose">
      <p class="text-xs uppercase tracking-[0.18em] opacity-60">Next</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
        <a href="/work" class="no-underline inline-flex items-center gap-2 border-b border-ink pb-1 dark:border-paper">
          View work
          <span aria-hidden="true">→</span>
        </a>
        <a href="/contact" class="no-underline opacity-70 hover:opacity-100">
          Contact
        </a>
        <a href={links.github} class="no-underline opacity-70 hover:opacity-100" rel="me noopener">
          GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
