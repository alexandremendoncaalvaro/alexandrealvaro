---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { links } from "../data/site";

const primary = [
  { label: "Email", value: links.email, href: `mailto:${links.email}` },
  { label: "LinkedIn", value: "linkedin.com/in/alexandrealvaro", href: links.linkedin },
  { label: "GitHub", value: "github.com/alexandremendoncaalvaro", href: links.github },
];

const secondary = [
  { label: "Baunilha", href: links.baunilha },
  { label: "Studio Baunilha", href: links.studioBaunilha },
  { label: "Ko-fi", href: links.kofi },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch — email, LinkedIn, GitHub."
>
  <section class="container-page pt-20 sm:pt-24 pb-10">
    <SectionHeading
      eyebrow="Contact"
      title="Get in touch."
      description="Best reached by email. For recruiters and technical leaders, LinkedIn works as well."
      as="h1"
    />
  </section>

  <section class="container-page pb-16">
    <ul class="max-w-prose divide-y divide-paper-line/70 dark:divide-white/10 border-y border-paper-line/70 dark:border-white/10">
      {
        primary.map((item) => (
          <li class="py-5 flex items-baseline justify-between gap-6">
            <span class="text-xs uppercase tracking-[0.18em] opacity-60 w-24 shrink-0">
              {item.label}
            </span>
            <a
              href={item.href}
              class="no-underline text-right font-mono text-[14px] break-all hover:opacity-70"
              rel="me noopener"
            >
              {item.value}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <hr class="rule container-page" />

  <section class="container-page py-16">
    <p class="text-xs uppercase tracking-[0.18em] opacity-60">Also</p>
    <ul class="mt-5 flex flex-wrap gap-x-8 gap-y-3 text-sm">
      {
        secondary.map((item) => (
          <li>
            <a href={item.href} class="no-underline opacity-70 hover:opacity-100" rel="noopener">
              {item.label} ↗
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
