---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="Page not found.">
  <section class="container-page pt-28 sm:pt-36 pb-24">
    <p class="text-xs uppercase tracking-[0.2em] opacity-60">404</p>
    <h1 class="mt-6 text-4xl sm:text-5xl font-serif font-normal tracking-tightish">
      Not found.
    </h1>
    <p class="mt-6 max-w-prose opacity-80">
      The page you are looking for does not exist — or has moved.
    </p>
    <div class="mt-8 text-sm">
      <a href="/" class="no-underline inline-flex items-center gap-2 border-b border-ink pb-1 dark:border-paper">
        Back home
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
